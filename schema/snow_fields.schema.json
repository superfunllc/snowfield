{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/superfunllc/snowfield/schema/snow_fields.schema.json",
  "title": "Snowfield Snow Fields Dataset",
  "type": "object",
  "required": [
    "dataset_name",
    "dataset_version",
    "schema_version",
    "records"
  ],
  "additionalProperties": false,
  "x-snowfield": {
    "local_regions": {
      "US": [
        "AZ",
        "CA",
        "CO",
        "ID",
        "MT",
        "NM",
        "NV",
        "OR",
        "UT",
        "WA",
        "WY"
      ]
    },
    "sync_modes": {
      "legacy": {
        "conflict_column": "name"
      },
      "catalog": {
        "conflict_column": "catalog_id"
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string"
    },
    "dataset_name": {
      "const": "snow_fields"
    },
    "dataset_version": {
      "type": "string",
      "pattern": "^\\d{4}\\.\\d{2}\\.\\d{2}([-.+][A-Za-z0-9_.-]+)?$"
    },
    "schema_version": {
      "const": 2
    },
    "description": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/snow_field"
      }
    }
  },
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "nullable_integer": {
      "type": [
        "integer",
        "null"
      ]
    },
    "nullable_number": {
      "type": [
        "number",
        "null"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "type",
        "name",
        "url",
        "retrieved_at"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "retrieved_at": {
          "$ref": "#/$defs/date"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "snow_field": {
      "type": "object",
      "required": [
        "catalog_id",
        "slug",
        "source",
        "source_id",
        "name",
        "country_code",
        "region_code",
        "region_name",
        "locality",
        "timezone",
        "lat",
        "lng",
        "elevation_ft",
        "base_elevation_ft",
        "summit_elevation_ft",
        "vertical_drop_ft",
        "status",
        "is_active",
        "is_verified",
        "tags",
        "updated_at",
        "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "type": "string",
          "pattern": "^[a-z0-9_.:-]+$",
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "source": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "source_id": {
          "type": "string",
          "minLength": 1,
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "legacy",
              "catalog"
            ]
          }
        },
        "country_code": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "region_code": {
          "type": "string",
          "minLength": 1,
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "region_name": {
          "type": "string",
          "minLength": 1,
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "locality": {
          "type": "string",
          "minLength": 1,
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "timezone": {
          "type": "string",
          "minLength": 1,
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "lat": {
          "$ref": "#/$defs/nullable_number",
          "minimum": -90,
          "maximum": 90,
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "lng": {
          "$ref": "#/$defs/nullable_number",
          "minimum": -180,
          "maximum": 180,
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "elevation_ft": {
          "$ref": "#/$defs/nullable_integer",
          "minimum": -2000,
          "maximum": 30000,
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "legacy",
              "catalog"
            ]
          }
        },
        "base_elevation_ft": {
          "$ref": "#/$defs/nullable_integer",
          "minimum": -2000,
          "maximum": 30000,
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "summit_elevation_ft": {
          "$ref": "#/$defs/nullable_integer",
          "minimum": -2000,
          "maximum": 30000,
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "vertical_drop_ft": {
          "$ref": "#/$defs/nullable_integer",
          "minimum": 0,
          "maximum": 30000,
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "status": {
          "enum": [
            "active",
            "inactive",
            "proposed",
            "retired"
          ],
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "is_active": {
          "type": "boolean",
          "x-snowfield": {
            "csv": true,
            "client_json": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "is_verified": {
          "type": "boolean",
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "updated_at": {
          "$ref": "#/$defs/date",
          "x-snowfield": {
            "csv": true,
            "sync_modes": [
              "catalog"
            ]
          }
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    }
  }
}
